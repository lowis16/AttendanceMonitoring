{
  "openapi": "3.0.1",
  "info": {
    "title": "Attendance Monitoring API",
    "description": "In-memory backend for the student attendance system.",
    "version": "v1"
  },
  "paths": {
    "/api/admin/register": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "RegisterAdmin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterAdminRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/admin/login": {
      "post": {
        "tags": [
          "Admin"
        ],
        "operationId": "AdminLogin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminLoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/admin/list": {
      "get": {
        "tags": [
          "Admin"
        ],
        "operationId": "ListAdmins",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/attendance/mark": {
      "post": {
        "tags": [
          "Attendance"
        ],
        "operationId": "MarkPresent",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StudentLoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/attendance/today": {
      "get": {
        "tags": [
          "Attendance"
        ],
        "operationId": "TodayAttendance",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/attendance/all": {
      "get": {
        "tags": [
          "Attendance"
        ],
        "operationId": "AllAttendance",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/": {
      "get": {
        "tags": [
          "Attendance Monitoring v2"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/attendance/portal/open": {
      "post": {
        "tags": [
          "Portal"
        ],
        "operationId": "OpenPortal",
        "parameters": [
          {
            "name": "adminUsername",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/attendance/portal/close": {
      "post": {
        "tags": [
          "Portal"
        ],
        "operationId": "ClosePortal",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/attendance/portal/status": {
      "get": {
        "tags": [
          "Portal"
        ],
        "operationId": "PortalStatus",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdminLoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterAdminRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StudentLoginRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "section": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}